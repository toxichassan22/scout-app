generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Team {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  label        String
  createdAt    DateTime @default(now())

  scores  Score[]
  reports Report[]
}

model Admin {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Judge {
  id           String   @id @default(uuid())
  name         String
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  scores Score[]
}

model Competition {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique // two_truths | genius | geography | video | custom
  type        String // auto_digital | manual_judged
  description String   @default("")
  isOpen      Boolean  @default(false)
  passcode    String? // judge passcode
  entryCode   String? // team entry code
  duration    Int? // seconds for timed auto competitions
  criteria    String   @default("[]") // JSON [{ key, label, maxScore }]
  createdAt   DateTime @default(now())

  scores    Score[]
  questions Question[]
  reports   Report[]
}

model Question {
  id            String      @id @default(uuid())
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  text          String
  options       String // JSON array (strings or {text, isLie})
  correctOption Int
  points        Float       @default(10)
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
}

model GeographyCountry {
  id       String @id @default(uuid())
  name     String
  capital  String
  currency String
  flag     String
  mapUrl   String
  sortOrder Int   @default(0)
}

model Score {
  id              String      @id @default(uuid())
  competitionId   String
  competition     Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  teamId          String
  team            Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  judgeId         String?
  judge           Judge?      @relation(fields: [judgeId], references: [id], onDelete: SetNull)
  values          String      @default("{}") // JSON
  total           Float
  submittedAt     DateTime    @default(now())
  editedByAdminId String?
  editedAt        DateTime?

  @@unique([competitionId, teamId])
}

model News {
  id               String   @id @default(uuid())
  title            String
  body             String
  photoUrl         String?
  createdByAdminId String
  createdAt        DateTime @default(now())
}

model Zone {
  id          String @id @default(uuid())
  numberLabel String
  name        String
  description String
  colorHex    String
  order       Int    @default(0)

  agendaItems AgendaItem[]
}

model AgendaItem {
  id          String  @id @default(uuid())
  title       String
  type        String // competition | workshop | ceremony
  zoneId      String
  zone        Zone    @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  startTime   String
  endTime     String
  description String
  isVisible   Boolean @default(true)
}

model Report {
  id            String       @id @default(uuid())
  teamId        String
  team          Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  competitionId String?
  competition   Competition? @relation(fields: [competitionId], references: [id], onDelete: SetNull)
  title         String       @default("")
  content       String       @default("")
  fileUrl       String
  fileName      String
  uploadedAt    DateTime     @default(now())
}
